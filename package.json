{
  "name": "pulse-ap2-x402-conformance",
  "version": "0.0.0",
  "description": "Offline conformance fixtures and a reference verifier for binding AP2 payment mandates to x402 EVM settlement records.",
  "license": "Apache-2.0",
  "author": "Prime Beat",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "pulse-ap2-x402-verify": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "fixtures",
    "docs",
    "README.md",
    "referent-table-public-conformance-implementation.md",
    "referent-table-public-conformance-implementation.sha256.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run --coverage",
    "test:unit": "vitest run --config vitest.mutation.config.ts",
    "test:x402-producer": "vitest run --config vitest.mutation.config.ts test/x402-producer.test.ts",
    "fixtures:generate": "tsx scripts/generate-fixtures.ts",
    "fixtures:verify": "tsx src/cli.ts fixtures/v0.1/cases.json",
    "fixtures:hash": "shasum -a 256 fixtures/v0.1/cases.json",
    "mutation": "stryker run",
    "audit:production": "npm audit --omit=dev --audit-level=high",
    "check:pack": "npm pack --dry-run",
    "ci": "npm run typecheck && npm run lint && npm run test:x402-producer && npm run test && npm run build && npm run fixtures:verify && npm run audit:production && npm run check:pack"
  },
  "dependencies": {
    "@x402/core": "2.19.0",
    "@x402/evm": "2.19.0",
    "canonicalize": "2.1.0",
    "commander": "15.0.0",
    "jose": "6.2.3",
    "viem": "2.55.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/node": "22.15.3",
    "@vitest/coverage-v8": "3.2.6",
    "tsx": "4.23.1",
    "typescript": "5.8.3",
    "vitest": "3.2.6"
  },
  "overrides": {
    "qs": "6.15.3"
  }
}
